{
  "name": "sockgate",
  "version": "1.0.0",
  "description": "Lightweight WebSocket client with auto-reconnect and SharedWorker-based cross-tab connection sharing.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./worker": {
      "types": "./dist/worker/worker.d.ts",
      "development": "./src/worker.ts",
      "import": "./dist/worker/worker.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm build:clean && pnpm build:esm && pnpm build:cjs && pnpm build:worker && pnpm build:pkg",
    "build:clean": "rm -rf dist",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:worker": "tsc -p tsconfig.worker.json",
    "build:pkg": "node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}));require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "lint": "oxlint --config .oxlintrc.json src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "websocket",
    "sharedworker",
    "reconnect",
    "auto-reconnect",
    "cross-tab"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^26.0.0",
    "oxlint": "^0.16.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}

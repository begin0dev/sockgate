{
  "name": "sockgate-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -F sockgate build",
    "test": "pnpm -F sockgate test",
    "lint": "pnpm -F sockgate lint",
    "format": "pnpm -r format",
    "dev": "pnpm --parallel --filter \"./examples/*\" dev",
    "dev:server": "pnpm -F @sockgate/example-server dev",
    "dev:react": "pnpm -F @sockgate/example-react dev"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0"
}
